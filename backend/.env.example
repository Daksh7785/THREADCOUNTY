# Backend
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5000,https://threadcounty.app


# JWT Secret (use a strong random value in production)
JWT_SECRET=your_super_secure_jwt_secret_change_this

# Database (Supabase — leave blank to use local JSON fallback)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email (Resend — required for transactional emails)
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@threadcounty.app
SUPPORT_EMAIL=support@threadcounty.app

# Payments — only if using real Stripe (Phase 14 Option B)
# Leave blank to use mock checkout
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Error monitoring (optional)
SENTRY_DSN=
